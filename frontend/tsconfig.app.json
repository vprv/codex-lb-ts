{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/index.css",
    "src/vite-env.d.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/hooks/use-theme.ts",
    "src/hooks/use-reduced-motion.ts",
    "src/features/accounts/api.ts",
    "src/features/accounts/schemas.ts",
    "src/features/accounts/components/accounts-page.tsx",
    "src/features/accounts/components/oauth-dialog.tsx",
    "src/features/accounts/hooks/use-oauth.ts",
    "src/features/dashboard/api.ts",
    "src/features/dashboard/components/dashboard-page.tsx",
    "src/features/settings/api.ts",
    "src/features/settings/components/settings-page.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/__integration__/**",
    "src/test/**",
    "src/features/auth/**",
    "src/features/api-keys/**",
    "src/features/firewall/**",
    "src/features/**/hooks/**",
    "src/features/**/schemas.ts",
    "src/features/accounts/components/windows-oauth-help.tsx"
  ]
}
